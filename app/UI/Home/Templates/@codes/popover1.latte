{embed "~popover", position: 'bottom', width: 'md'}
	{block trigger}
		<button class="bg-purple-500 hover:bg-purple-700 text-white font-bold py-2 px-4 rounded">
			User Info
		</button>
	{/block}
	{block title}Profile{/block}
	{block content}
		<p class="font-medium">John Doe</p>
		<p class="text-gray-400">john@example.com</p>
		<p class="mt-2">Full-stack developer with 5 years of experience.</p>
	{/block}
{/embed}
